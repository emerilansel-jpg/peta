{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "(www\\.)?straight\\.ltd" }],
      "destination": "/straight.html"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
