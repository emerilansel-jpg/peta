# Copy this file to .env.local for local dev (which points at staging Supabase).
# DO NOT commit .env.local — it's gitignored.
#
# In Vercel, set these per-environment under Settings → Environment Variables.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
